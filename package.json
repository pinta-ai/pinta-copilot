{
  "name": "@pinta-ai/pinta-copilot",
  "version": "0.6.0",
  "description": "Generic OTLP forwarder + guard for GitHub Copilot hook events (CLI + VS Code extension)",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinta-ai/pinta-copilot.git"
  },
  "homepage": "https://github.com/pinta-ai/pinta-copilot#readme",
  "bugs": {
    "url": "https://github.com/pinta-ai/pinta-copilot/issues"
  },
  "scripts": {
    "bump": "node scripts/bump.mjs",
    "build": "tsc --noEmit && npm run build:cjs && npm run build:esm",
    "build:cjs": "esbuild src/index.ts src/tools/doctor.ts src/tools/install-hooks.ts --bundle --platform=node --format=cjs --target=node18 --minify --outbase=src --outdir=dist",
    "build:esm": "esbuild src/index.mts --bundle --platform=node --format=esm --target=node18 --minify --banner:js=\"import{createRequire as __pintaCreateRequire}from 'node:module';const require=__pintaCreateRequire(import.meta.url);\" --outfile=dist/index.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:import": "node scripts/smoke-import.mjs",
    "mock-server": "npx tsx tools/mock-server.ts",
    "install-hooks": "node dist/tools/install-hooks.js",
    "uninstall-hooks": "node dist/tools/install-hooks.js --uninstall",
    "doctor": "node dist/tools/doctor.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@pinta-ai/core": "^0.5.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
