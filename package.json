{
  "name": "@pinta-ai/pinta-copilot",
  "version": "0.1.0",
  "description": "Generic OTLP forwarder + guard for GitHub Copilot hook events (CLI + VS Code extension)",
  "main": "dist/index.js",
  "license": "PolyForm-Noncommercial-1.0.0",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/awarecorp/pinta-copilot.git"
  },
  "homepage": "https://github.com/awarecorp/pinta-copilot#readme",
  "bugs": {
    "url": "https://github.com/awarecorp/pinta-copilot/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "mock-server": "npx tsx tools/mock-server.ts",
    "install-hooks": "node dist/tools/install-hooks.js",
    "uninstall-hooks": "node dist/tools/install-hooks.js --uninstall",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
